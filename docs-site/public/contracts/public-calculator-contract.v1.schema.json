{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edithatogo.github.io/microcosting_healthservices/contracts/public-calculator-contract.v1.schema.json",
  "title": "Public Calculator Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "calculator_id",
    "pricing_year",
    "input_schema_version",
    "output_schema_version",
    "required_input_columns",
    "required_output_columns"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)*$",
      "const": "1.0",
      "description": "Version of the public calculator contract schema."
    },
    "calculator_id": {
      "type": "string",
      "enum": ["acute", "adjust", "ed", "mh", "outpatients", "subacute"],
      "description": "Stable calculator identifier."
    },
    "pricing_year": {
      "type": "string",
      "pattern": "^(?:201[3-9]|202[0-6])$",
      "description": "Supported IHACPA pricing year label."
    },
    "input_schema_version": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)*$",
      "const": "1.0",
      "description": "Version of the input column schema."
    },
    "output_schema_version": {
      "type": "string",
      "pattern": "^\\d+(?:\\.\\d+)*$",
      "const": "1.0",
      "description": "Version of the output column schema."
    },
    "required_input_columns": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Required adapter input columns."
    },
    "required_output_columns": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Required adapter output columns."
    }
  },
  "examples": [
    {
      "schema_version": "1.0",
      "calculator_id": "acute",
      "pricing_year": "2025",
      "input_schema_version": "1.0",
      "output_schema_version": "1.0",
      "required_input_columns": [
        "DRG",
        "LOS",
        "ICU_HOURS",
        "ICU_OTHER",
        "PAT_SAMEDAY_FLAG",
        "PAT_PRIVATE_FLAG"
      ],
      "required_output_columns": [
        "NWAU25"
      ]
    }
  ]
}
