{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/emergency-code-mapping-pipeline/emergency-code-mapping-pipeline.schema.json",
  "title": "Emergency code mapping pipeline contract",
  "description": "Schema for synthetic metadata-only emergency code mapping pipeline fixtures, including mapping bundle manifests, dry-run summaries, diagnostics, local-only references, and the no-proprietary-payload boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_id",
    "tool",
    "privacy",
    "commands",
    "mapping_bundle_manifest_schema",
    "mapping_bundle_record_types",
    "compatibility_rules",
    "outputs",
    "provenance",
    "examples"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "contract_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "package",
        "entry_point"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "contains_phi",
        "notes"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "synthetic"
          ]
        },
        "contains_phi": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "mode",
          "status",
          "inputs",
          "outputs"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "mapping-bundle-manifest",
              "compatibility-validation",
              "dry-run-summary",
              "boundary-check",
              "local-reference-resolution"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "preview",
              "stable"
            ]
          },
          "inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "mapping_bundle_manifest_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "description",
        "required_fields",
        "field_definitions"
      ],
      "properties": {
        "version": {
          "type": "string",
          "const": "1.0"
        },
        "description": {
          "type": "string"
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "field_definitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "type",
              "purpose"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "mapping_bundle_record_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "purpose"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "label": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "compatibility_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "severity",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "label": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_manifest_format",
        "validation_report_format",
        "diagnostic_format",
        "mapping_summary_format",
        "compatible_state",
        "incompatible_state",
        "unresolved_state"
      ],
      "properties": {
        "bundle_manifest_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "validation_report_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "diagnostic_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "mapping_summary_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "compatible_state": {
          "type": "string",
          "const": "pass"
        },
        "incompatible_state": {
          "type": "string",
          "const": "fail"
        },
        "unresolved_state": {
          "type": "string",
          "const": "unknown"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fields",
        "checksum_algorithm"
      ],
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "checksum_algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        }
      }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
