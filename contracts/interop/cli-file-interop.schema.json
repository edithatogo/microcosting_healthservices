{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/interop/cli-file-interop.schema.json",
  "title": "NWAU CLI/file interop contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "interop_id",
    "tool",
    "schema",
    "privacy",
    "commands",
    "file_formats",
    "diagnostics",
    "provenance",
    "examples"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "interop_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "package",
        "entry_point"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        }
      }
    },
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^contracts/interop/.+\\.schema\\.json$"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "contains_phi",
        "notes"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "synthetic",
            "anonymized"
          ]
        },
        "contains_phi": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "input_formats",
          "output_formats",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "input_formats": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "csv",
                "parquet",
                "arrow"
              ]
            }
          },
          "output_formats": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "csv",
                "parquet",
                "arrow",
                "json"
              ]
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "stable",
              "preview"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "file_formats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "csv",
          "parquet",
          "arrow"
        ]
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "location",
        "fields"
      ],
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "location": {
          "type": "string",
          "enum": [
            "stderr"
          ]
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fields",
        "checksum_algorithm"
      ],
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "checksum_algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        }
      }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
