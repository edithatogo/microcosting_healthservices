{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/source-scanner/source-scanner.schema.json",
  "title": "IHACPA source scanner contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scanner_id",
    "tool",
    "privacy",
    "commands",
    "source_categories",
    "outputs",
    "provenance",
    "examples"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "scanner_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "package",
        "entry_point"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "contains_phi",
        "notes"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "synthetic"
          ]
        },
        "contains_phi": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "mode",
          "status",
          "inputs",
          "outputs"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "scan",
              "add-year"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "preview",
              "stable"
            ]
          },
          "inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "source_categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "purpose"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "label": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run_format",
        "draft_manifest_format",
        "gap_record_format"
      ],
      "properties": {
        "dry_run_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "draft_manifest_format": {
          "type": "string",
          "enum": [
            "json",
            "yaml"
          ]
        },
        "gap_record_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fields",
        "checksum_algorithm"
      ],
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "checksum_algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        }
      }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}

