{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/kotlin-native-binding/kotlin-native-binding.schema.json",
  "title": "Kotlin/Native binding contract",
  "description": "Schema for synthetic metadata-only Kotlin/Native binding manifests.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "binding_bundle_id",
    "tool",
    "privacy",
    "calculator_contract_alignment",
    "request_response_models",
    "surfaces",
    "diagnostics",
    "errors",
    "fixture_gates",
    "build_readiness",
    "provenance",
    "examples"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "binding_bundle_id": {
      "type": "string"
    },
    "privacy": {
      "type": "object",
      "required": [
        "classification",
        "contains_phi"
      ],
      "properties": {
        "classification": {
          "const": "synthetic"
        },
        "contains_phi": {
          "const": false
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1
    },
    "build_readiness": {
      "type": "object",
      "required": [
        "kotlin_native",
        "c_abi",
        "service"
      ]
    }
  }
}
