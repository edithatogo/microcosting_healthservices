{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/kotlin-native-binding/kotlin-native-binding.schema.json",
  "title": "Kotlin/Native binding contract",
  "description": "Schema for synthetic metadata-only Kotlin/Native binding manifests, service and Arrow/Parquet fallback declarations, diagnostics, errors, fixture gates, and build readiness notes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_bundle_id",
    "tool",
    "privacy",
    "calculator_contract_alignment",
    "request_response_models",
    "surfaces",
    "transport_fallbacks",
    "diagnostics",
    "errors",
    "fixture_gates",
    "build_readiness",
    "provenance",
    "examples"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "binding_bundle_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "package",
        "entry_point"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "contains_phi",
        "notes"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "synthetic"
          ]
        },
        "contains_phi": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "calculator_contract_alignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_contract",
        "aligned_fields",
        "compatibility_policy"
      ],
      "properties": {
        "source_contract": {
          "type": "string"
        },
        "aligned_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "compatibility_policy": {
          "type": "string"
        }
      }
    },
    "request_response_models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "kind",
          "fields",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "request",
              "response",
              "diagnostic",
              "error"
            ]
          },
          "fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "transport",
          "role",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "label": {
            "type": "string"
          },
          "transport": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "primary",
              "fallback",
              "observability",
              "validation"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "transport_fallbacks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "priority",
          "transport",
          "when",
          "output_contract",
          "notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "transport": {
            "type": "string",
            "enum": [
              "service",
              "arrow",
              "parquet"
            ]
          },
          "when": {
            "type": "string"
          },
          "output_contract": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "trigger",
          "output"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error"
            ]
          },
          "trigger": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message",
          "retryable",
          "notes"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^KOTLIN_NATIVE_BINDING_[0-9]{3}$"
          },
          "message": {
            "type": "string"
          },
          "retryable": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "fixture_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "description",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked"
            ]
          },
          "description": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "build_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ko",
        "kotlin_native",
        "jvm"
      ],
      "properties": {
        "ko": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "coordinates",
            "minimum_java",
            "packaging"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "ready",
                "preview",
                "blocked"
              ]
            },
            "coordinates": {
              "type": "string"
            },
            "minimum_java": {
              "type": "string"
            },
            "packaging": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "kotlin_native": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "plugin",
            "minimum_kotlin",
            "kotlin_dsl"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "ready",
                "preview",
                "blocked"
              ]
            },
            "plugin": {
              "type": "string"
            },
            "minimum_kotlin": {
              "type": "string"
            },
            "kotlin_dsl": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "jvm": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "bytecode_target",
            "test_framework"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "ready",
                "preview",
                "blocked"
              ]
            },
            "bytecode_target": {
              "type": "string"
            },
            "test_framework": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fields",
        "checksum_algorithm"
      ],
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "checksum_algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        }
      }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
