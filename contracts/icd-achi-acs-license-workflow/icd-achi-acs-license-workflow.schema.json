{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/icd-achi-acs-license-workflow/schema.json",
  "title": "ICD-10-AM ACHI ACS licensed product workflow contract",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "workflow_id", "privacy"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "workflow_id": {"type": "string"},
    "privacy": {
      "type": "object",
      "required": ["classification", "contains_phi"],
      "properties": {
        "classification": {"type": "string", "const": "synthetic"},
        "contains_phi": {"type": "boolean", "const": false}
      }
    }
  }
}
