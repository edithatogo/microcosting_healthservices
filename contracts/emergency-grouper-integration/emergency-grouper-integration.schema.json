{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/contracts/emergency-grouper-integration/emergency-grouper-integration.schema.json",
  "title": "Emergency grouper integration contract",
  "description": "Schema for synthetic metadata-only fixtures covering precomputed emergency outputs, local-only grouper or service references, compatibility diagnostics, and the no-proprietary-payload boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "integration_id",
    "tool",
    "schema",
    "privacy",
    "commands",
    "integration_surface_types",
    "compatibility_rules",
    "outputs",
    "provenance",
    "examples"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "integration_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "package",
        "entry_point"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        }
      }
    },
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^contracts/emergency-grouper-integration/.+\\.schema\\.json$"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "contains_phi",
        "notes"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "synthetic"
          ]
        },
        "contains_phi": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "mode",
          "status",
          "inputs",
          "outputs"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "precomputed-output-manifest",
              "compatibility-diagnostics",
              "local-reference-resolution",
              "boundary-check"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "preview",
              "stable"
            ]
          },
          "inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "integration_surface_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "purpose"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "label": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "compatibility_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "severity",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "label": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_manifest_format",
        "validation_report_format",
        "diagnostic_format",
        "compatible_state",
        "incompatible_state",
        "unresolved_state"
      ],
      "properties": {
        "output_manifest_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "validation_report_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "diagnostic_format": {
          "type": "string",
          "enum": [
            "json"
          ]
        },
        "compatible_state": {
          "type": "string",
          "const": "pass"
        },
        "incompatible_state": {
          "type": "string",
          "const": "fail"
        },
        "unresolved_state": {
          "type": "string",
          "const": "unknown"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fields",
        "checksum_algorithm"
      ],
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "checksum_algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        }
      }
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "path",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
